{
  "name": "design-system-monorepo",
  "private": true,
  "workspaces": [
    "impls/*",
    "playground"
  ],
  "scripts": {
    "build:pkg": "bun run --filter @byteowlz/design-system build",
    "build:playground": "bun run --filter @byteowlz/design-system-playground build",
    "dev": "bun run --filter @byteowlz/design-system-playground dev",
    "typecheck": "bun run --filter '*' --elide-lines tsc --noEmit"
  }
}
